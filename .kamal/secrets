# Secrets resolvidos em runtime pelo Kamal. Single source of truth: SOPS file
# em ~/.config/iedora/secrets.sops.yaml (encriptado com age key em
# ~/.config/sops/age/keys.txt).
#
# Para adicionar um secret novo a prod:
#   1. sops ~/.config/iedora/secrets.sops.yaml         (abre editor, adiciona linha, salva)
#   2. infra/live/kamal/deploy.yml: lista o nome em env.secret (ou no accessory)
#   Próximo `bun run deploy` injecta no container — não precisas de editar este ficheiro.
#
# Secrets dinâmicos (gerados por `gh`/`tofu`) ficam abaixo, fora do SOPS,
# porque rodam fora do ciclo de edição manual.

export SOPS_AGE_KEY_FILE=$HOME/.config/sops/age/keys.txt
SOPS_FILE=$HOME/.config/iedora/secrets.sops.yaml

# Importa TODOS os pares chave=valor do SOPS para o env. Adicionas ao SOPS,
# fica disponível aqui — sem listas a manter.
eval "$(sops -d --output-type dotenv "$SOPS_FILE" | sed 's/^/export /')"

# ─── Dinâmicos (não vivem no SOPS porque são regenerados) ────────────
KAMAL_REGISTRY_PASSWORD=$(gh auth token)
TUNNEL_TOKEN=$(cat infra/live/tofu/.tunnel-token)
S3_ACCESS_KEY=$(cat infra/live/tofu/.s3-access-key)
S3_SECRET_KEY=$(cat infra/live/tofu/.s3-secret-key)

# ─── Derivados (compostos a partir do SOPS) ──────────────────────────
# Postgres accessory — hostname = iedora-web-postgres na kamal network.
CORE_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@iedora-web-postgres:5432/core
MENU_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@iedora-web-postgres:5432/menu
IMOPUSH_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@iedora-web-postgres:5432/imopush

# OpenObserve — aliases para o que o accessory/collector espera.
ZO_ROOT_USER_PASSWORD=${OPENOBSERVE_ADMIN_PASSWORD}
OTEL_AUTH_HEADER="Basic $(printf '%s' "eduardoferdcarvalho@gmail.com:${OPENOBSERVE_ADMIN_PASSWORD}" | base64)"
