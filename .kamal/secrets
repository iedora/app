# Kamal evaluates this file with shell semantics. Lines look like
# KEY=value_or_$(expression). Working directory is the repo root.
#
# No actual secret values live here — only references. Safe to commit.

# Cloudflare tunnel token: read from Tofu state (encrypted at rest).
TUNNEL_TOKEN=$(tofu -chdir=infra/tofu output -raw tunnel_token 2>/dev/null)

# GitHub Container Registry: use the `gh` CLI's token.
# Requires `gh auth refresh -s write:packages` once.
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# App secrets — exported by the Makefile from infra/.env.
BETTER_AUTH_SECRET=$BETTER_AUTH_SECRET
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
DATABASE_URL=postgres://postgres:$POSTGRES_PASSWORD@meta-menu-postgres:5432/metamenu
REDIS_URL=redis://meta-menu-redis:6379
MINIO_ROOT_USER=$MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=$MINIO_ROOT_PASSWORD
S3_ACCESS_KEY=$MINIO_ROOT_USER
S3_SECRET_KEY=$MINIO_ROOT_PASSWORD
