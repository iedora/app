# Single source of truth for LOCAL DEV env.
# Consumed by:
#   - docker compose          (bun run dev:up / down / logs / reset)
#   - drizzle migrations      (bun run dev:migrate)
#   - next dev                (bun run dev)
#
# Loaded via `bun --env-file=dev/local.env` and `docker compose --env-file`.
# Tracked — no secrets, only local-only fake values.

# --- docker compose ---
S3MOCK_HTTP_PORT=9090
S3MOCK_INITIAL_BUCKETS=iedora-data,iedora-assets

# --- Postgres (one server, three databases — created by config/postgres/init.sql) ---
MENU_DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/menu
CORE_DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/core
IMOPUSH_DATABASE_URL=postgresql://postgres:Password1!@localhost:5432/imopush

# --- better-auth ---
CORE_SECRET=dev-iedora-auth-secret-do-not-use-in-prod-32chars
CORE_BASE_URL=http://localhost:3000
CORE_TRUSTED_ORIGINS=http://localhost:3000
CORE_COOKIE_DOMAIN=localhost
NEXT_PUBLIC_CORE_URL=http://localhost:3000/core
NEXT_PUBLIC_MENU_URL=http://localhost:3000
NEXT_PUBLIC_IMOPUSH_URL=http://localhost:3000/imopush

DISABLE_RATE_LIMIT=true

# --- S3 (adobe/s3mock on :9090) ---
S3_ENDPOINT=http://localhost:9090
S3_REGION=us-east-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=iedora-assets
