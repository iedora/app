---
/**
 * Editorial header — wordmark + one-sentence statement + a single
 * mailto link. No interactive form, no slide-open pane. Contact is a
 * plain `<a href="mailto:…">`; the rest of the page sets its own
 * height with no hidden form occupying the cell.
 */
import { Wordmark } from "@iedora/design-system";

const contactEmail = "hi@iedora.com";
---

<header class="house">
  <h1 class="wordmark-wrap">
    <Wordmark variant="display" />
  </h1>
  <p class="intro-line">A quiet house for digital craftsmanship.</p>
  <a class="contact-link" href={`mailto:${contactEmail}`} aria-label={`Write to ${contactEmail}`}>
    <span class="contact-link__label">Write to us</span>
    <span class="contact-link__addr">{contactEmail}</span>
    <span class="contact-link__arrow" aria-hidden="true">↗</span>
  </a>
</header>

<style>
  .house {
    position: relative;
    padding: 56px 0 64px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }
  .wordmark-wrap {
    margin: 0;
    display: inline-flex;
  }

  /* One sentence under the wordmark — fades in shortly after the
     letter-by-letter reveal lands. */
  .intro-line {
    margin: 0;
    max-width: 38ch;
    font-family: var(--serif);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-70);
    text-wrap: pretty;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity var(--d-5) 0.85s var(--ease), transform var(--d-5) 0.85s var(--ease);
  }
  body.ds-loaded .intro-line { opacity: 1; transform: translateY(0); }

  /* The contact action — a plain mailto link, label + monospaced
     address + cinnabar arrow. Fades in a beat after the intro line. */
  .contact-link {
    display: inline-flex;
    align-items: baseline;
    gap: 14px;
    margin-top: 4px;
    padding: 0;
    background: none;
    border: 0;
    color: var(--ink);
    text-decoration: none;
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity var(--d-5) 1.0s var(--ease),
      transform var(--d-5) 1.0s var(--ease),
      color var(--d-2) var(--ease);
  }
  body.ds-loaded .contact-link { opacity: 1; transform: translateY(0); }
  .contact-link__label {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--ink-55);
  }
  .contact-link__addr {
    font-family: var(--serif);
    font-size: 22px;
    line-height: 1;
    font-weight: 400;
    color: var(--ink);
    border-bottom: 1px solid var(--ink-22);
    padding-bottom: 3px;
    transition: border-color var(--d-2) var(--ease);
  }
  .contact-link__arrow {
    color: var(--cinnabar);
    font-size: 18px;
    line-height: 1;
    transition: transform var(--d-2) var(--ease);
  }
  .contact-link:hover .contact-link__addr,
  .contact-link:focus-visible .contact-link__addr { border-color: var(--ink); }
  .contact-link:hover .contact-link__arrow,
  .contact-link:focus-visible .contact-link__arrow { transform: translate(2px, -2px); }
  .contact-link:focus-visible {
    outline: 2px solid var(--cinnabar);
    outline-offset: 6px;
  }

  @media (max-width: 1080px) {
    .house { padding: 40px 0 48px; }
  }
  @media (max-width: 680px) {
    .house { padding: 24px 0 32px; gap: 20px; }
    .contact-link { gap: 10px; flex-wrap: wrap; }
    .contact-link__addr { font-size: 19px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .intro-line, .contact-link { transition: none; }
  }
</style>
