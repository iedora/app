---
/**
 * iedora.com — the brand landing page.
 *
 * Aligned with the menu landing's editorial chrome so the company reads
 * as one design language. Composition mirrors menu/.../landing-page.tsx:
 *
 *   PageProgress → sticky Nav → Hero (eyebrow + h1 + tagline + CTAs)
 *   → Practice section (3 hairline-divided feats: Slowly · Quietly · Together)
 *   → Products section (one product card per iedora work: Menu)
 *   → Closing CTA → footer-bar (contact links) → footer-sig (signature).
 *
 * Every chrome class is a `.ds-*` primitive from @iedora/design-system —
 * no bespoke section CSS lives here anymore. The page is fully static
 * (Astro output: 'static') and reads with JS disabled: only the
 * page-progress rail + the wordmark letter reveal are JS-driven.
 *
 * Every interactive element carries a `data-test-id` (cross-product
 * hard rule 1). Selectors target by intent, never by visible text.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  Nav,
  NavActions,
  NavBrand,
  NavLink,
  NavLinks,
  PageProgress,
  Wordmark,
} from "@iedora/design-system";

const contactEmail = "hi@iedora.com";
const menuUrl = "https://menu.iedora.com";
---

<BaseLayout>
  <PageProgress />

  <Nav sticky data-test-id="house-nav">
    <NavBrand>
      <a
        href="#top"
        class="house-brand"
        aria-label="Iedora home"
        data-test-id="house-brand"
      >
        <Wordmark variant="inline" />
      </a>
    </NavBrand>

    <NavLinks aria-label="House">
      <NavLink href="#practice" data-test-id="house-nav-practice">Practice</NavLink>
      <NavLink href="#products" data-test-id="house-nav-products">Products</NavLink>
      <NavLink href="#contact" data-test-id="house-nav-contact">Contact</NavLink>
    </NavLinks>

    <NavActions>
      <a
        href={menuUrl}
        class="ds-btn ds-btn--primary"
        data-test-id="house-nav-cta"
        rel="noopener"
      >
        <span>Open menu</span>
        <span class="ds-btn__arrow" aria-hidden="true">→</span>
      </a>
    </NavActions>
  </Nav>

  <main class="ds-shell house-root" id="top">
    <!-- Hero ───────────────────────────────────────────────────── -->
    <header class="ds-hero" id="hero" data-test-id="house-hero">
      <span class="ds-eyebrow">
        <span class="ds-eyebrow__idx">/ 00</span>
        <span>House of software</span>
      </span>
      <h1 class="ds-hero__h ds-hero__h--dot">
        We build software the way <em>a house</em> is built
      </h1>
      <p class="ds-hero__tagline">
        Foundations first, then the frame. Patient work, quiet
        interfaces, and tools we are happy to live with for many seasons.
      </p>
      <div class="ds-hero__ctas">
        <a
          class="ds-btn ds-btn--primary"
          href={menuUrl}
          rel="noopener"
          data-test-id="house-hero-cta-menu"
        >
          <span>See our first product</span>
          <span class="ds-btn__arrow" aria-hidden="true">→</span>
        </a>
        <a
          class="ds-btn"
          href={`mailto:${contactEmail}`}
          data-test-id="house-hero-cta-contact"
        >
          <span>Write to us</span>
        </a>
      </div>
      <p class="ds-hero__trust">
        A small house in Oporto and Lisboa · Available for new works in 2026
      </p>
    </header>

    <!-- Practice ─────────────────────────────────────────────── -->
    <section class="ds-section" id="practice" data-test-id="house-practice">
      <div class="ds-section__head ds-reveal">
        <span class="ds-eyebrow">
          <span class="ds-eyebrow__idx">/ 01</span>
          <span>Practice</span>
        </span>
        <h2 class="ds-section__h ds-section__h--dot">Three ways we work</h2>
        <p class="ds-section__intro">
          Plain language, long horizons, and a roadmap that is short on
          purpose.
        </p>
      </div>

      <div class="ds-feat-grid">
        <article class="ds-feat ds-reveal" data-test-id="house-practice-slowly">
          <span class="ds-feat__num">/ 01 · Slowly</span>
          <h3 class="ds-feat__h">We measure in years, not in quarters.</h3>
          <p class="ds-feat__p">
            Some things only become true with time. Our roadmap is short
            because the craft deserves it; the horizon is long because
            people will still be using this in five.
          </p>
        </article>

        <article
          class="ds-feat ds-reveal"
          style="--rd: 120ms"
          data-test-id="house-practice-quietly"
        >
          <span class="ds-feat__num">/ 02 · Quietly</span>
          <h3 class="ds-feat__h">Plain language. No urgency.</h3>
          <p class="ds-feat__p">
            Honest words on screen. Hairlines instead of boxes. The brand
            is the work, not the noise around it. If a button needs to
            shout, it is the wrong button.
          </p>
        </article>

        <article
          class="ds-feat ds-reveal"
          style="--rd: 240ms"
          data-test-id="house-practice-together"
        >
          <span class="ds-feat__num">/ 03 · Together</span>
          <h3 class="ds-feat__h">AI at the desk, never on the page.</h3>
          <p class="ds-feat__p">
            We use AI as a collaborator: in the code, in the docs, in the
            test suite. What ships is software that knows what it is and
            says so. No surprise chatbots, no theatre.
          </p>
        </article>
      </div>
    </section>

    <!-- Products ─────────────────────────────────────────────── -->
    <section class="ds-section" id="products" data-test-id="house-products">
      <div class="ds-section__head ds-reveal">
        <span class="ds-eyebrow">
          <span class="ds-eyebrow__idx">/ 02</span>
          <span>Products</span>
        </span>
        <h2 class="ds-section__h ds-section__h--dot">What lives in the house</h2>
        <p class="ds-section__intro">
          One product in service today; more rooms under construction.
        </p>
      </div>

      <div class="ds-product-grid">
        <article class="ds-product-card ds-reveal" data-test-id="house-product-menu">
          <header class="ds-product-card__head">
            <span class="ds-product-card__tier">Menu · in service</span>
            <span class="ds-product-card__price">
              <span class="ds-product-card__amt-main">€0</span>
              <span class="ds-product-card__amt-sub">free for one room</span>
            </span>
          </header>
          <p class="ds-product-card__desc">
            One QR on the table. The menu behind it changes whenever you
            want. For the corner café and the place that opens four
            nights a week.
          </p>
          <ul class="ds-product-card__feats">
            <li>Drag-and-drop menu builder</li>
            <li>Multiple translations, allergens, dietary tags</li>
            <li>Hour-by-hour scan analytics</li>
            <li>Always free for one restaurant</li>
          </ul>
          <div class="ds-product-card__foot">
            <a
              class="ds-btn ds-btn--primary"
              href={menuUrl}
              rel="noopener"
              data-test-id="house-product-menu-cta"
            >
              <span>Open menu</span>
              <span class="ds-btn__arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </article>

        <article
          class="ds-product-card ds-reveal"
          style="--rd: 140ms"
          data-test-id="house-product-soon"
        >
          <header class="ds-product-card__head">
            <span class="ds-product-card__tier">Next room · drawing</span>
            <span class="ds-product-card__price">
              <span class="ds-product-card__amt-main">soon</span>
              <span class="ds-product-card__amt-sub">in design</span>
            </span>
          </header>
          <p class="ds-product-card__desc">
            We are sketching the next work. If you carry the kind of
            problem that wants patience and a long horizon, write to us
            and we will read it carefully.
          </p>
          <ul class="ds-product-card__feats">
            <li>Made in the same hand as menu</li>
            <li>Plain language, hairline interfaces</li>
            <li>Same prices, same restraint</li>
          </ul>
          <div class="ds-product-card__foot">
            <a
              class="ds-btn"
              href={`mailto:${contactEmail}`}
              data-test-id="house-product-soon-cta"
            >
              <span>Send a brief</span>
            </a>
          </div>
        </article>
      </div>
    </section>

    <!-- Closing ─────────────────────────────────────────────── -->
    <section class="ds-closing" id="contact" data-test-id="house-closing">
      <div class="ds-closing__inner ds-reveal">
        <span class="ds-eyebrow">
          <span class="ds-eyebrow__idx">/ 03</span>
          <span>At the door</span>
        </span>
        <h2 class="ds-closing__h">Pull up a chair</h2>
        <div class="ds-closing__ctas">
          <a
            class="ds-btn ds-btn--primary"
            href={`mailto:${contactEmail}`}
            data-test-id="house-closing-cta"
          >
            <span>Write to {contactEmail}</span>
            <span class="ds-btn__arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Footer ─────────────────────────────────────────────── -->
    <footer class="ds-footer-bar" data-test-id="house-footer">
      <div class="ds-footer-bar__inner">
        <span>
          Iedora · made in Oporto &amp; Lisboa · MMXXVI
        </span>
        <span class="ds-footer-bar__links">
          <a
            href={`mailto:${contactEmail}`}
            data-test-id="house-footer-contact"
          >
            {contactEmail}
          </a>
          <a
            href={menuUrl}
            rel="noopener"
            data-test-id="house-footer-menu"
          >
            menu.iedora.com
          </a>
        </span>
      </div>
    </footer>

    <div class="ds-footer-sig" data-test-id="house-signature">
      <div>
        <span class="ds-footer-sig__built">
          Built in Iedora<span class="ds-footer-sig__built-dot">.</span>
        </span>
      </div>
      <div class="ds-footer-sig__center">
        <span>MMXXVI</span>
      </div>
      <div class="ds-footer-sig__right">
        <span>Index</span>
        <span>Colophon</span>
        <span>Press</span>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  /* House-specific composition tweaks. Everything chrome-y lives in the
     design system; this file only carries the page-shell rhythm. */

  .house-root {
    position: relative;
    z-index: 1;
  }

  .house-brand {
    display: inline-flex;
    align-items: baseline;
    color: var(--ink);
    text-decoration: none;
  }

  /* Hero italic emphasis — the design-system rule for `<em>` keeps
     its weight at 400 italic; nothing to override here. */
</style>

<!--
  One-time motion init:
  - Flag `body.ds-loaded` after first paint so the wordmark letter reveal
    plays without gating the LCP (the wordmark is rendered statically;
    we only animate post-paint).
  - Flag the hero with `ds-hero--in` so its tagline/CTAs/trust line
    cascade-fade once `ds-loaded` lands.
  - Drive `.ds-pageprog__fill` via `--ds-pageprog-progress` on scroll/resize.
  - Add `.in` to every `.ds-reveal` once it intersects the viewport
    (single-shot — `unobserve` after firing).

  Above-the-fold content is statically visible — animations never gate
  the LCP candidate (the wordmark + the h1 paint immediately).
-->
<script is:inline>
  (() => {
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    // ── Flag body.ds-loaded + cascade the hero in ────────────────────
    requestAnimationFrame(() =>
      requestAnimationFrame(() => {
        document
          .querySelectorAll(".ds-wordmark")
          .forEach((w) => w.classList.add("ds-wordmark--reveal"));
        document.body.classList.add("ds-loaded");
        const hero = document.getElementById("hero");
        if (hero) hero.classList.add("ds-hero--in");
      }),
    );

    // ── Page progress ───────────────────────────────────────────────
    const fill = document.querySelector(".ds-pageprog__fill");
    let raf = 0;
    function update() {
      raf = 0;
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      const p = max > 0 ? Math.min(1, Math.max(0, h.scrollTop / max)) : 0;
      if (fill) fill.style.setProperty("--ds-pageprog-progress", p.toFixed(4));
    }
    function onScroll() {
      if (!raf) raf = requestAnimationFrame(update);
    }
    update();
    if (!reduceMotion) {
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll, { passive: true });
    }

    // ── Reveal on scroll (fires once per element) ───────────────────
    if (!reduceMotion && typeof IntersectionObserver !== "undefined") {
      const targets = document.querySelectorAll(".ds-reveal");
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("in");
              io.unobserve(entry.target);
            }
          }
        },
        { rootMargin: "0px 0px -10% 0px", threshold: 0.05 },
      );
      targets.forEach((el) => io.observe(el));
    } else if (reduceMotion) {
      document
        .querySelectorAll(".ds-reveal")
        .forEach((el) => el.classList.add("in"));
    }
  })();
</script>
