# TLS termination via Cloudflare DNS-01 (bypassa o CF proxy — LE issue
# via API token sem precisar de challenge HTTP-01 público).
#
# Routes:
#   git.iedora.com → gitea:3000 (Gitea OCI registry + UI)
#
# Para adicionar mais hosts (ex: grafana.iedora.com → grafana:3000):
# replicar o bloco. Cada hostname obtém o seu cert.

{
	email eduardoferdcarvalho@gmail.com
}

git.iedora.com {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}
	reverse_proxy gitea:3000
}
