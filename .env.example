# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/metamenu

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Cache / Queue
REDIS_URL=redis://localhost:6379

# Object storage (S3-compatible: LocalStack local, R2/S3 in prod)
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=metamenu

# Multi-instance prod only — generate with: openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
# DEPLOYMENT_VERSION=
